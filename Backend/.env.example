# Mongo connection string. For Docker compose use `mongodb://mongo:27017/leadsrack`.
# For Atlas: `mongodb+srv://<user>:<pass>@<cluster>/<db>`.
MONGODB_URI=mongodb://localhost:27017/leadsrack

# JWT signing key. Minimum 32 chars. Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Token lifetime. Accepts "7d", "12h", "30m", or a number of seconds.
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins (CORS).
CORS_ORIGIN=http://localhost:3000

# HTTP port.
PORT=4000

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# bcrypt cost factor. 10 is fine for dev; use 12+ in production.
BCRYPT_ROUNDS=10

# development | test | production
NODE_ENV=development
