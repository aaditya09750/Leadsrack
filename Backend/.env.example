# =============================================================================
# Backend environment template. Copy to `.env` and fill in values.
#
# - In production (Render, Fly, Railway, etc) set these in the host's dashboard.
# - Never commit a real `.env` file. JWT_SECRET and MONGODB_URI are secrets.
# =============================================================================

# Mongo connection string.
#   Local dev:           mongodb://localhost:27017/leadsrackDB
#   Docker compose:      mongodb://mongo:27017/leadsrackDB
#   Production (Atlas):  mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/leadsrackDB

# JWT signing key. Minimum 32 chars. Generate with: openssl rand -base64 48
# On Render, you can let `generateValue: true` in render.yaml auto-generate this.
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Token lifetime. Accepts "7d", "12h", "30m", or a number of seconds.
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed CORS origins (no trailing slashes).
#   Dev:        http://localhost:3000
#   Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# HTTP port. Render injects PORT automatically; locally 4000 is the convention.
PORT=4000

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# bcrypt cost factor. 10 is fine for dev. Use 12 in production for stronger
# password hashing at a small CPU cost (~250ms per login on Render free tier).
BCRYPT_ROUNDS=10

# development | test | production
# Set to "production" on Render to enable JSON logs, disable autoIndex,
# and skip pino-pretty transport.
NODE_ENV=development
